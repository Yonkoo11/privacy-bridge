# Flow EVM
FLOW_RPC_URL=https://testnet.evm.nodes.onflow.org
FLOW_PRIVATE_KEY=           # Deployer private key (never commit)
FLOW_BRIDGE_ADDRESS=0xd1959eA3d6ca0631f2e617ac7CE71e297E5328Ca

# Starknet
STARKNET_RPC_URL=http://localhost:5050
STARKNET_BRIDGE_ADDRESS=    # From deploy-devnet.mjs output
STARKNET_ACCOUNT_ADDRESS=   # Deployer/relayer account
RELAYER_PRIVATE_KEY=        # Starknet account private key (never commit)

# Storacha (optional -- receipt upload)
W3UP_EMAIL=                 # w3up-client email for IPFS receipts

# Web app (set during build for production)
NEXT_PUBLIC_BRIDGE_ADDRESS=0xd1959eA3d6ca0631f2e617ac7CE71e297E5328Ca
NEXT_PUBLIC_RELAYER_URL=http://localhost:3001
NEXT_PUBLIC_CALLDATA_URL=http://localhost:3002
NEXT_PUBLIC_BASE_PATH=      # Set to /privacy-bridge for GitHub Pages
